# Phase 0 asserts on the namespace count (CREATE SCHEMA is the only
# fully-typed stmt in the fixture); Phase 1+ asserts tighten as the
# fold's coverage grows to match pgpb_to_snapshot.c.
lean_test(
    name = "pg_catalog_fold_pipeline_test",
    srcs = [
        "Pg/Catalog/Fold.lean",
        "Pg/Catalog/FoldPipelineTest.lean",
        "Pg/Catalog/Oid.lean",
        "Pg/Catalog/RegTypes.lean",
        "Pg/Catalog/Snapshot.lean",
        "Pg/Catalog/Tables.lean",
        "Pg/Query/Top.lean",
        "//tools/pgpb_to_lean_ast:SmokeFixtureTyped.lean",
    ],
    entry = "Pg/Catalog/FoldPipelineTest.lean",
