structure RawStmt where
  stmt               : _root_.Option Node           := none
  stmtLocation       : _root_.Int32                 := 0
  stmtLen            : _root_.Int32                 := 0
-- deriving Inhabited (deferred — expensive in mutual blocks)

structure ParseResult where
  version            : _root_.Int32                 := 0
  stmts              : _root_.List RawStmt          := []
-- deriving Inhabited (deferred — expensive in mutual blocks)

structure ScanToken where
  start              : _root_.Int32                 := 0
  end_               : _root_.Int32                 := 0
  token              : Token                        := .nul
