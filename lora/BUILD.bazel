load(
    "@rules_lora//lora:defs.bzl",
    "lora_base_model",
    "lora_dataset",
    "lora_recipe",
    "lora_train",
)

# Pg.Ir local-model fine-tune. The 17-cluster corpus extracted by
# `tools/corpus_extract/extract.py` → `to_messages_v1.py` feeds
# into rules_lora's `messages_v1` SFT schema.
#
# Strategic intent: train a small local model that authors Pg.Ir
# Lean specs given Postgres C source, removing the hosted-LLM
# (Haiku) dependency for Stream A.
#
# Held-out plan: 14 train / 3 test split. Candidate test clusters:
#   - uuid          (cmp-hash-fixed16 shape)
#   - int_div       (arith-divbyzero-ereport shape)
#   - bytea         (palloc-varlena shape)
# These three exercise three distinct cluster shapes — a model that
# generalizes across them is genuinely useful.
#
# Initial recipe: small base + LoRA. Qwen 2.5 1.5B-Instruct is the
# smallest model with strong code understanding; 1.5B + LoRA fits
# Mac M-series MLX and RunPod A40 budgets equally. Bump rank if
# under-fit shows up.

# ─── Dataset ─────────────────────────────────────────────────────────────────
#
# Source-of-truth JSONL is generated by:
#   python3 tools/corpus_extract/to_messages_v1.py
# from the corpus at `tools/corpus_extract/corpus.jsonl`. We commit
# the messages_v1 file so the dataset hash is stable for the
# lora_train recipe pinning.

lora_dataset(
    name = "pgir_sft",
    src = "//tools/corpus_extract:sft_messages_v1.jsonl",
    # 17 clusters total; min validates the file isn't empty / corrupt.
    min_examples = 14,
    schema = "messages_v1",
)

# ─── Base model ──────────────────────────────────────────────────────────────
#
# Qwen 2.5 1.5B-Instruct: strong code generation, small enough for
# rapid local-Mac iteration via MLX, fits a single A40 GPU on RunPod
# at int8. The Lean spec target language is well within Qwen's
# instruction-following surface.

lora_base_model(
    name = "qwen25_15b",
    repo = "Qwen/Qwen2.5-1.5B-Instruct",
    revision = "main",
)

# ─── Recipe ──────────────────────────────────────────────────────────────────
#
# LoRA rank 16 / alpha 32 on Q/K/V/O attention. Three epochs over
# 17 examples — small corpus, so we want enough epochs to learn the
# spec structure without overfitting. Validation gate is the eval
# harness (`bazel run :eval_held_out`) which runs three gates per
# held-out cluster, not loss on a val-loss tail.

lora_recipe(
    name = "rank16_a32_3epoch",
    alpha = 32,
    epochs = 3,
    framework = "torchtune",
    grad_accum_steps = 8,
    learning_rate = "2e-4",
    micro_batch_size = 1,
    rank = 16,
    target_modules = [
        "q_proj",
        "k_proj",
        "v_proj",
        "o_proj",
    ],
)

# ─── Train ───────────────────────────────────────────────────────────────────
#
# `local` backend: builds the TrainingJobSpec; does NOT actually
# train (smoke-only). Use this to validate the dataset + recipe
# wiring without burning GPU minutes.
#
# `bazel build //lora:pgir_lora_jobspec` produces the JobSpec.
# For real training: change backend to "runpod" and run
# `bazel run //lora:pgir_lora.train`.

lora_train(
    name = "pgir_lora_jobspec",
    backend = "local",
    base = ":qwen25_15b",
    dataset = ":pgir_sft",
    recipe = ":rank16_a32_3epoch",
)
